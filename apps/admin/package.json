{
  "name": "@libra-net/admin",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm api:build && vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest --config jest.config.js --coverage --colors",
    "api:build": "run-s api:clean openapi2aspida",
    "api:clean": "rimraf src/apis/bin",
    "openapi2aspida": "openapi2aspida -c=aspida.config.cjs",
    "lint-staged": "lint-staged --config .lintstagedrc.js",
    "check-changed": "CHANGED_FILES=$( (git diff --name-only HEAD && git ls-files --others --exclude-standard) | grep -E '\\\\.(ts|tsx)$' | grep '^apps/admin/' || true); if [ -n \"$CHANGED_FILES\" ]; then echo \"Processing files:\"; echo \"$CHANGED_FILES\"; echo \"$CHANGED_FILES\" | sed 's|^apps/admin/||' | xargs eslint --cache --cache-location .eslintcache --max-warnings 0; fi && npx tsc --noEmit --incremental --tsBuildInfoFile .tsbuildinfo"
  },
  "dependencies": {
    "@aspida/axios": "^1.14.0",
    "@fontsource-variable/noto-serif-jp": "^5.2.9",
    "@fontsource/dm-mono": "^5.2.7",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.0",
    "aspida": "^1.14.0",
    "axios": "^1.13.6",
    "openapi2aspida": "^0.24.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/react-vite": "^10.2.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/router-devtools": "^1.166.7",
    "@tanstack/router-vite-plugin": "^1.166.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "hygen": "^6.2.11",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "storybook": "^10.2.19",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
